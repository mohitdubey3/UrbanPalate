@{
    ViewData["Title"] = "Home Page";
}
<div class="container my-5">
    <section class="hero-card shadow-lg py-5 mb-5">
        <h1 class="display-3 fw-bold text-white">Welcome to Urbon Restaurant</h1>
        <p class="lead text-white text-center">Fresh, delicious meals served with love. Cozy ambience. Book a table or explore our menu.</p>
        <div class="d-flex justify-content-center gap-2 mt-4">
            <a class="btn btn-light text-dark rounded-pill px-4 py-2 fw-bold" asp-area="" asp-controller="Home" asp-action="Contact">Book a Table</a>
            <a class="btn btn-light text-dark rounded-pill px-4 py-2 fw-bold" asp-area="" asp-controller="Product" asp-action="Index">See Menu</a>
        </div>
    </section>
</div>

<div class="container">
    <div class="hero-card shadow-lg">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-3 fw-bold mb-3">Delicious Food,<br>Delivered Fast.</h1>
                <p class="fs-5 mb-4 opacity-75">Experience the taste of premium meals delivered hot and fresh to your doorstep within minutes.</p>
                <a class="btn btn-light text-dark rounded-pill px-4 py-2 fw-bold" asp-controller="Order" asp-action="Create">Order Now &rarr;</a>
            </div>
            <div class="col-md-6 text-center position-relative">
                <div class="hero-img-container">
                    <img src="https://wallpapers.com/images/hd/traditional-thali-platter-indian-food-7ppdmw8bs4n1f36j.jpg" class="rounded-circle img-fluid shadow" alt="Foods">
                </div>
                <span class="badge bg-white text-danger position-absolute top-0 end-0 rounded-pill p-2"><i class="fa fa-fire"></i> Hot</span>
            </div>
        </div>
    </div>
</div>

<section class="container my-5">
    <h4 class="fw-bold mb-4"><i class="fa fa-utensils text-muted me-2"></i> Inspiration for Your <span class="text-warning">First Order</span></h4>
    <div class="row g-4">
        <div class="col-md-2 col-6 position-relative">
            <img src="https://tse1.mm.bing.net/th/id/OIP.49QLJX5hiayymjfHobf_tgHaEK?rs=1&pid=ImgDetMain&o=7&rm=3" class="category-img shadow-sm" alt="Snacks">
            <span class="cat-label">Snacks</span>
        </div>
        <div class="col-md-2 col-6 position-relative">
            <img src="https://img.freepik.com/premium-photo/indian-lunch-dinner-main-course-food-group-includes-paneer-butter-masala-dal-makhani-palak-paneer-roti-rice-etc-selective-focus_466689-6858.jpg?w=2000" class="category-img shadow-sm" alt="Main Course">
            <span class="cat-label">Main Course</span>
        </div>
        <div class="col-md-2 col-6 position-relative">
            <img src="https://cdn.loveandlemons.com/wp-content/uploads/2021/06/summer-desserts-1.jpg" class="category-img shadow-sm" alt="Desserts">
            <span class="cat-label">Desserts</span>
        </div>
        <div class="col-md-2 col-6 position-relative">
            <img src="https://img.freepik.com/premium-photo/closeup-slice-pepperoni-pizza-with-melted-cheese-stretching_198067-245797.jpg?w=2000" class="category-img shadow-sm" alt="Pizza">
            <span class="cat-label">Pizza</span>
        </div>
        <div class="col-md-2 col-6 position-relative">
            <img src="https://www.thespruceeats.com/thmb/DXZoAJoKTPS7BKEyk4H-Gw3puhc=/6016x4016/filters:fill(auto,1)/steamed-momos-wontons-1957616-hero-01-1c59e22bad0347daa8f0dfe12894bc3c.jpg" class="category-img shadow-sm" alt="Burgers">
            <span class="cat-label">Momos</span>
        </div>
        <div class="col-md-2 col-6 position-relative">
            <img src="https://tse3.mm.bing.net/th/id/OIP.xAxz2Ecb2EO2138VPcqiKQHaE8?rs=1&pid=ImgDetMain&o=7&rm=3" class="category-img shadow-sm" alt="Burgers">
            <span class="cat-label">Burgers</span>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <i class="bi bi-basket2-fill fs-1 text-dark"></i>
            <h4 class="mt-2">Fresh Ingredients</h4>
            <p class="text-muted">Locally sourced and seasonally inspired.</p>
        </div>
        <div class="col-md-4 mb-4">
            <i class="bi bi-clock-fill fs-1 text-dark"></i>
            <h4 class="mt-2">Fast Service</h4>
            <p class="text-muted">Prompt, friendly, and attentive staff.</p>
        </div>
        <div class="col-md-4 mb-4">
            <i class="bi bi-star-fill fs-1 text-dark"></i>
            <h4 class="mt-2">Top Rated</h4>
            <p class="text-muted">Loved by our customers for taste and service.</p>
        </div>
    </div>
</section>

