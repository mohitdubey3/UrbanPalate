@using UrbanPalate.Models
@model IEnumerable<Ingredient>

@{
    ViewBag.Title = "List Of The Ingredients";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>Ingredients</h1>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Create New Ingredient
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            @if (Model.Any())
            {
                <div class="card shadow">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-bordered align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (Ingredient i in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-light text-dark">@Html.DisplayFor(modelItem => i.Name)</span>
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group" role="group">
                                                <a asp-action="Details" asp-route-id="@i.IngredientId" class="btn btn-info btn-sm" title="View Details">
                                                    <i class="bi bi-eye"></i> Show Item
                                                </a>
                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <a asp-action="Edit" asp-route-id="@i.IngredientId" class="btn btn-warning btn-sm" title="Edit Ingredient">
                                                        <i class="bi bi-pencil"></i> Rename
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@i.IngredientId" class="btn btn-danger btn-sm" title="Delete Ingredient">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    <strong>No Ingredients Found</strong> There are no ingredients in the system yet.
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Create" class="alert-link">Create one now</a>
                    }
                </div>
            }
        </div>
    </div>
</div>