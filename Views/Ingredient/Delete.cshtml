@using UrbanPalate.Models
@model Ingredient
@{
    ViewBag.Title = $"Delete {Model.Name} Ingredient";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Confirm Delete</h5>
                </div>
                <div class="card-body">
                    <h6 class="card-title">Are you sure you want to delete this ingredient?</h6>
                    <p class="card-text text-muted">This action cannot be undone.</p>
                    <h4 class="my-3">@Model.Name</h4>
                </div>
                <div class="card-footer bg-light">
                    <form asp-action="Delete" method="post" class="d-flex gap-2">
                        <input type="hidden" asp-for="IngredientId" />
                        <button type="submit" class="btn btn-danger">Delete</button>
                        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>