@using UrbanPalate.Models
@model Ingredient

@{
    ViewBag.Title = $"Edit {Model.Name} Ingredient";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Edit Ingredient</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="IngredientId" />
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="Enter ingredient name" />
                            <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light">
                    <form asp-action="Edit" method="post" class="d-flex gap-2">
                        <input type="hidden" asp-for="IngredientId" />
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
