@using UrbanPalate.Models
@model OrderViewModel

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <h1 class="mb-4">
                <i class="bi bi-cart-fill"></i> My Cart
            </h1>

            <form asp-action="PlaceOrder" method="post">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Order Items</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Product</th>
                                        <th>Quantity</th>
                                        <th>Price</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.OrderItems.Count; i++)
                                    {
                                        var sum = Model.OrderItems[i].Quantity * Model.OrderItems[i].Price;
                                        <tr>
                                            <td>@Model.OrderItems[i].ProductName</td>
                                            <td class="text-center"><span class="badge bg-info">@Model.OrderItems[i].Quantity</span></td>
                                            <td>@Model.OrderItems[i].Price.ToString("C")</td>
                                            <td class="fw-bold">@sum.ToString("C")</td>
                                        </tr>
                                    }
                                    <tr class="table-active fw-bold">
                                        <td colspan="3" class="text-end">Total Amount:</td>
                                        <td class="bg-primary text-white">@Model.TotalAmount.ToString("C")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-light">
                        <div class="d-flex gap-2 justify-content-between">
                            <a href="javascript:history.back()" class="btn btn-secondary">Go Back</a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle"></i> Place Order
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>